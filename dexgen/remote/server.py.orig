import asyncio
import gc
import json
import logging
import os
import shutil
import threading
import time
import uuid
from dataclasses import dataclass, field
from pathlib import Path
from typing import Dict, Optional

import torch
import uvicorn
from fastapi import BackgroundTasks, FastAPI, Depends, File, Form, HTTPException, Request, Security, UploadFile
from fastapi.responses import FileResponse, JSONResponse
from fastapi.security.api_key import APIKeyHeader
from pydantic import BaseModel
from pydantic_settings import BaseSettings

# --- Configuration & Logging ---
logging.basicConfig(level=logging.INFO, format="%(asctime)s - %(name)s - %(levelname)s - %(message)s")
logger = logging.getLogger("DexGen_RemoteNode")

class Settings(BaseSettings):
    API_KEY: Optional[str] = os.getenv("DEXGEN_API_KEY")
    OUTPUT_DIR: str = "/tmp/dexgen_outputs"
    GDRIVE_DIR: str = "/content/drive/MyDrive/DexGen_Renders"

    def __init__(self, **data):
        super().__init__(**data)
        if not self.API_KEY or self.API_KEY == "starsilk_remote_auth_key":
            self.API_KEY = uuid.uuid4().hex
            # Log with prominent visual separators so Colab users see it
            print("\n" + "="*60)
            print(f"🔐 DEXGEN API KEY AUTO-GENERATED: {self.API_KEY}")
            print("="*60 + "\n")

settings = Settings()
os.makedirs(settings.OUTPUT_DIR, exist_ok=True)

# --- Security ---
API_KEY_NAME = "X-API-Key"
api_key_header = APIKeyHeader(name=API_KEY_NAME, auto_error=True)

async def get_api_key(api_key_header: str = Security(api_key_header)):
    if api_key_header == settings.API_KEY:
        return api_key_header
    raise HTTPException(status_code=403, detail="Could not validate API KEY")

# --- Core Job Management ---
@dataclass
class JobState:
    job_id: str
    kind: str  # "generate" or "animate"
    prompt_assembly: str
    seed: int
    status: str = "queued"
    progress: float = 0.0
    result_filename: Optional[str] = None
    error_message: Optional[str] = None

# Global state
job_queue = asyncio.Queue() # For incoming jobs
active_jobs: Dict[str, JobState] = {} # For polling status
job_state_lock = threading.Lock() # Guard for active_jobs dictionary
gpu_lock = threading.Lock() # Global lock: Only one inference task at a time
app_start_time = time.time()

# --- Model Loading (Lazy) ---
pipeline_generate = None
pipeline_animate = None

def load_flux_model():
    """Load Flux.1-schnell with NF4 quantization."""
    global pipeline_generate
    if pipeline_generate is not None:
        return pipeline_generate

    logger.info("Loading Flux.1-schnell (NF4 Quantization)...")
    from diffusers import FluxPipeline
    from transformers import BitsAndBytesConfig

    # NF4 configuration
    quantization_config = BitsAndBytesConfig(
        load_in_4bit=True,
        bnb_4bit_quant_type="nf4",
        bnb_4bit_compute_dtype=torch.bfloat16
    )

    try:
        pipeline_generate = FluxPipeline.from_pretrained(
            "black-forest-labs/FLUX.1-schnell",
            quantization_config=quantization_config,
            torch_dtype=torch.bfloat16,
        )
        # Enable memory optimizations
        pipeline_generate.enable_model_cpu_offload()
        logger.info("Flux.1-schnell loaded successfully.")
    except Exception as e:
        logger.error(f"Error loading Flux: {e}")
        pipeline_generate = None
        raise RuntimeError(f"Failed to initialize Flux: {e}")
    return pipeline_generate

def load_video_model():
    """Load SVD or I2VGen-XL for Image-to-Video."""
    global pipeline_animate
    if pipeline_animate is not None:
        return pipeline_animate

    logger.info("Loading I2VGen-XL pipeline...")
    from diffusers import I2VGenXLPipeline
    
    try:
        pipeline_animate = I2VGenXLPipeline.from_pretrained(
            "ali-vilab/i2vgen-xl", 
            torch_dtype=torch.float16, 
            variant="fp16"
        )
        # T4 Optimization: Requires sequential offload due to 16GB VRAM constraint
        pipeline_animate.enable_sequential_cpu_offload()
        # Decode VAE in chunks
        pipeline_animate.vae.enable_slicing()
        logger.info("I2VGen-XL loaded successfully.")
    except Exception as e:
        logger.error(f"Error loading Video Model: {e}")
        pipeline_animate = None
        raise RuntimeError(f"Failed to initialize Video Model: {e}")
    return pipeline_animate

def cleanup_memory():
    """Explicitly clean up GPU memory after inference."""
    gc.collect()
    torch.cuda.empty_cache()
    logger.info("Executed manual gc.collect() and torch.cuda.empty_cache().")

# --- Background Worker Thread ---
def gpu_worker():
    """Background thread that consumes from the job queue and safely executes inference."""
    logger.info("GPU Worker thread started.")
    
    # Needs a new event loop for the background thread since asyncio queues are bound to the main loop
    # We will use thread-safe methods to interact with the queue passed from main loop
    
    while True:
        try:
            # We don't have a direct async loop in this thread, so we'll poll the queue or use a threading.Event
            # For simplicity in this structure where `job_queue` is asyncio, it's better to run an async loop 
            # *inside* the thread, or let FastAPI's BackgroundTasks handle the queuing natively.
            
            # Since the requirement specifies a "background Thread for the GPU job queue" and "Global GPU lock":
            time.sleep(1) # Replaced with actual queue processing in the async app lifecycle 
            
        except Exception as e:
            logger.error(f"Worker thread error: {e}")

# Alternative: Async Worker Task (More Pythonic for FastAPI)
async def async_gpu_worker():
    """Async worker that pulls jobs and executes them safely under the thread lock."""
    logger.info("Async GPU Worker started.")
    while True:
        job_req = await job_queue.get()
        job_id = job_req["job_id"]
        
        with job_state_lock:
            job_state = active_jobs[job_id]
            job_state.status = "running"
            
        logger.info(f"Starting execution for job: {job_id}")

        try:
            # Acquire Global GPU Lock
            # We run the actual heavy lifting in a threadpool to prevent blocking the async event loop
            with gpu_lock:
                if job_state.kind == "generate":
                    await asyncio.to_thread(_process_generate, job_req, job_state)
                elif job_state.kind == "animate":
                    await asyncio.to_thread(_process_animate, job_req, job_state)
                
            with job_state_lock:
                job_state.status = "done"
                job_state.progress = 1.0
            
        except Exception as e:
            logger.error(f"Job {job_id} failed: {e}")
            with job_state_lock:
                job_state.status = "error"
                job_state.error_message = str(e)
            
        finally:
            cleanup_memory()
            job_queue.task_done()

def _process_generate(req: dict, state: JobState):
    """Synchronous generation logic to be run under a lock in a Thread."""
    pipe = load_flux_model()
    if not pipe:
        raise RuntimeError("Failed to load Flux pipeline.")
    
    # 1. Prompt Assembly
    final_prompt = f"{req['character_lock']}, {req['style_preset']}, {req['prompt']}".strip(", ")
    state.prompt_assembly = final_prompt
    
    # 2. Generator setup
    generator = torch.Generator("cpu").manual_seed(req["seed"])
    
    # 3. Inference
    logger.info(f"[{state.job_id}] Running flux-1-schnell inference...")
    image = pipe(
        final_prompt,
        output_type="pil",
        num_inference_steps=req["steps"],
        generator=generator,
    ).images[0]
    
    # 4. Save
    filename = f"gen_{state.job_id}.png"
    filepath = os.path.join(settings.OUTPUT_DIR, filename)
    image.save(filepath)
    state.result_filename = filename
    
    # 5. Direct-to-Drive (Optional)
    if req["save_to_drive"] and os.path.exists(Path(settings.GDRIVE_DIR).parent):
        os.makedirs(settings.GDRIVE_DIR, exist_ok=True)
        drive_path = os.path.join(settings.GDRIVE_DIR, filename)
        shutil.copy2(filepath, drive_path)
        logger.info(f"[{state.job_id}] Copied to Google Drive: {drive_path}")

def _process_animate(req: dict, state: JobState):
    """Synchronous animation logic to be run under a lock in a Thread."""
    pipe = load_video_model()
    if not pipe:
        raise RuntimeError("Failed to load Video pipeline.")
    
    from diffusers.utils import load_image
    from diffusers.utils import export_to_video
    
    # 1. Load Image
    image = load_image(req["image_path"])
    image = image.resize((1024, 1024)) # I2VGen-XL optimal res
    
    # 2. Generator Setup
    generator = torch.manual_seed(state.seed)
    
    # 3. Inference
    logger.info(f"[{state.job_id}] Running I2VGen-XL inference...")
    frames = pipe(
        prompt=req["prompt"],
        image=image,
        num_inference_steps=50,
        target_fps=req["fps"],
        generator=generator
    ).frames[0]
    
    # 4. Save
    filename = f"anim_{state.job_id}.mp4"
    filepath = os.path.join(settings.OUTPUT_DIR, filename)
    export_to_video(frames, filepath, fps=req["fps"])
    state.result_filename = filename
    
    # Cleanup uploaded source image
    if os.path.exists(req["image_path"]):
        os.remove(req["image_path"])

# --- FastAPI App ---
app = FastAPI(title="DexGen Remote Node", version="1.0")

@app.on_event("startup")
async def startup_event():
    logger.info("Starting up background tasks and preloading models...")
    # Start the async queue consumer
    asyncio.create_task(async_gpu_worker())
    
    # Preload models to eliminate first-request cold-start timeout
    try:
        load_flux_model()
        # Since I2VGen is 16GB VRAM on T4, keeping both in memory with sequential offload
        # requires them to be cached but actually offloaded.
        load_video_model()
        logger.info("Models preloaded successfully.")
    except Exception as e:
        logger.error(f"Failed to preload models during startup: {e}")

# --- Models ---
class GenerateRequest(BaseModel):
    prompt: str
    character_lock: str = ""
    style_preset: str = ""
    negative_prompt: str = ""
    seed: int = 42
    width: int = 1024
    height: int = 1024
    steps: int = 4
    save_to_drive: bool = False

# --- Endpoints ---
@app.get("/v1/health", dependencies=[Depends(get_api_key)])
def health_check():
    gpu_name = "None"
    if torch.cuda.is_available():
        gpu_name = torch.cuda.get_device_name(0)
    return {"status": "online", "gpu": gpu_name}

@app.get("/v1/stats", dependencies=[Depends(get_api_key)])
def system_stats():
    uptime = time.time() - app_start_time
    vram_total_mb = 0
    vram_used_mb = 0
    vram_free_mb = 0
    
    if torch.cuda.is_available():
        t = torch.cuda.get_device_properties(0).total_memory
        r = torch.cuda.memory_reserved(0)
        a = torch.cuda.memory_allocated(0)
        
        vram_total_mb = t // (1024 * 1024)
        vram_used_mb = a // (1024 * 1024)
        vram_free_mb = (t - a) // (1024 * 1024)
        
    return {
        "uptime_seconds": int(uptime),
        "vram_total_mb": vram_total_mb,
        "vram_used_mb": vram_used_mb,
        "vram_free_mb": vram_free_mb,
    }
    
    with job_state_lock:
        stats["active_jobs_count"] = len([j for j in active_jobs.values() if j.status in ["queued", "running"]])
        
    return stats

@app.post("/v1/generate", dependencies=[Depends(get_api_key)])
async def generate_image(req: GenerateRequest):
    job_id = f"job_{uuid.uuid4().hex[:12]}"
    
    state = JobState(
        job_id=job_id,
        kind="generate",
        prompt_assembly=f"{req.character_lock}, {req.style_preset}, {req.prompt}".strip(", "),
        seed=req.seed
    )
    with job_state_lock:
        active_jobs[job_id] = state
    
    # Enqueue work
    await job_queue.put({
        "job_id": job_id,
        "prompt": req.prompt,
        "character_lock": req.character_lock,
        "style_preset": req.style_preset,
        "seed": req.seed,
        "steps": req.steps,
        "save_to_drive": req.save_to_drive
    })
    
    return {"job_id": job_id, "status": "queued"}

@app.post("/v1/animate", dependencies=[Depends(get_api_key)])
async def animate_image(
    prompt: str = Form(...),
    fps: int = Form(7),
    num_frames: int = Form(14),
    motion_strength: int = Form(127),
    file: UploadFile = File(...)
):
    job_id = f"job_{uuid.uuid4().hex[:12]}"
    
    # Save uploaded file temporarily
    temp_img_path = os.path.join(settings.OUTPUT_DIR, f"temp_{job_id}_{file.filename}")
    with open(temp_img_path, "wb") as buffer:
        shutil.copyfileobj(file.file, buffer)
        
    state = JobState(
        job_id=job_id,
        kind="animate",
        prompt_assembly=prompt,
        seed=42 # Or generate a random one
    )
    with job_state_lock:
        active_jobs[job_id] = state
    
    # Enqueue work
    await job_queue.put({
        "job_id": job_id,
        "prompt": prompt,
        "fps": fps,
        "num_frames": num_frames,
        "motion_strength": motion_strength,
        "image_path": temp_img_path
    })
    
    return {"job_id": job_id, "status": "queued"}

@app.get("/v1/jobs/{job_id}", dependencies=[Depends(get_api_key)])
def get_job_status(job_id: str):
    with job_state_lock:
        if job_id not in active_jobs:
            raise HTTPException(status_code=404, detail="Job not found")
        
        state = active_jobs[job_id]
        
    return {
        "job_id": state.job_id,
        "kind": state.kind,
        "status": state.status,
        "progress": state.progress,
        "result_filename": state.result_filename,
        "error_message": state.error_message
    }

@app.get("/v1/jobs/{job_id}/download", dependencies=[Depends(get_api_key)])
def download_result(job_id: str):
    with job_state_lock:
        if job_id not in active_jobs:
            raise HTTPException(status_code=404, detail="Job not found")
        state = active_jobs[job_id]
        
    if state.status != "done" or not state.result_filename:
        raise HTTPException(status_code=400, detail="Job not completed or missing result")
        
    # Ensure path safety against directory traversal
    base_dir = os.path.abspath(settings.OUTPUT_DIR)
    filepath = os.path.abspath(os.path.join(base_dir, state.result_filename))
    
    # Verify the resolved path is actually strictly under the base_dir
    # commonpath ensures we don't fall victim to partial prefix matches (e.g. /tmp/dexgen_outputs_evil)
    if os.path.commonpath([base_dir, filepath]) != base_dir:
        raise HTTPException(status_code=400, detail="Invalid filename")

    if not os.path.exists(filepath):
        raise HTTPException(status_code=404, detail="File missing on disk")
        
    media_type = "video/mp4" if filepath.endswith(".mp4") else "image/png"
    return FileResponse(filepath, media_type=media_type, filename=state.result_filename)

if __name__ == "__main__":
    uvicorn.run(app, host="127.0.0.1", port=8000)

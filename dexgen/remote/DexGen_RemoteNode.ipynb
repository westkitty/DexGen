                "if not os.path.exists(local_server_path):\n",
                "    print(\"You need the server.py file. Please upload it to Colab, or we can create it dynamically here.\")\n",
                "    # For this standalone notebook, we assume server.py is uploaded next to it.\n",
                "    # Otherwise, you would write the contents of server.py directly here using `%%writefile server.py`\n",
                "else:\n",
                "    print(\"Found server.py\")"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "import nest_asyncio\n",
                "import uvicorn\n",
                "\n",
                "# Apply nest_asyncio to allow Uvicorn to run within the active Colab IPython event loop\n",
                "nest_asyncio.apply()\n",
                "\n",
                "print(\"Starting FastAPI server...\")\n",
                "from server import app  # Assuming server.py is uploaded\n",
                "\n",
                "# Run Uvicorn in the main thread (nest_asyncio allows this)\n",
                "uvicorn.run(app, host=\"127.0.0.1\", port=8000)"
            ]
        }

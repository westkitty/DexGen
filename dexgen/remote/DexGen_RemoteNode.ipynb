            "source": [
                "import os\n",
                "\n",
                "# Optional: Mount Google Drive if you want Direct-to-Drive saves\n",
                "MOUNT_DRIVE = False\n",
                "\n",
                "if MOUNT_DRIVE:\n",
                "    from google.colab import drive\n",
                "    drive.mount('/content/drive')\n",
                "    print(\"Drive mounted successfully.\")\n",
                "else:\n",
                "    print(\"Skipping Google Drive mount.\")"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "# Download cloudflared\n",
                "!wget -q https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64.deb\n",
                "!dpkg -i cloudflared-linux-amd64.deb\n",
                "print(\"Cloudflared installed successfully.\")"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "import threading\n",
                "import time\n",
                "import subprocess\n",
                "\n",
                "# Function to run the Cloudflare tunnel in the background\n",
                "def start_cloudflare_tunnel(port):\n",
                "    print(f\"Starting Cloudflare tunnel on port {port}...\")\n",
                "    # Standard subprocess to run the tunnel\n",
                "    command = f\"cloudflared tunnel --url http://127.0.0.1:{port}\"\n",
                "    tunnel_process = subprocess.Popen(command, shell=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)\n",
                "    \n",
                "    # Wait a few seconds for the tunnel to establish\n",
                "    time.sleep(5) \n",
                "    \n",
                "    # Extract the custom TryCloudflare URL from the output\n",
                "    try_url = None\n",
                "    for line in iter(tunnel_process.stdout.readline, b''):\n",
                "        line_str = line.decode('utf-8').strip()\n",
                "        # The URL usually looks like https://random-words.trycloudflare.com\n",
                "        if 'https://' in line_str and '.trycloudflare.com' in line_str:\n",
                "            # Extract the actual URL part\n",
                "            parts = line_str.split(' ')\n",
                "            for part in parts:\n",
                "                if part.startswith('https://') and part.endswith('.trycloudflare.com'):\n",
                "                    try_url = part\n",
                "                    break\n",
                "        if try_url:\n",
                "            break\n",
                "            \n",
                "    if try_url:\n",
                "        print(f\"\\n{'='*50}\\n\")\n",
                "        print(f\"BRIDGE URL FOUND! Paste this into the Orchestrator UI:\\n\\n{try_url}\\n\")\n",
                "        print(f\"{'='*50}\\n\")\n",
                "    else:\n",
                "        print(\"\\nCould not automatically parse the Cloudflare URL. Please check the logs below.\\n\")\n",
                "        \n",
                "    # Keep printing output if needed for debugging\n",
                "    # for line in iter(tunnel_process.stdout.readline, b''):\n",
                "    #     print(line.decode('utf-8').strip())\n",
                "\n",
                "# Start tunnel in a background thread\n",
                "tunnel_thread = threading.Thread(target=start_cloudflare_tunnel, args=(8000,), daemon=True)\n",
                "tunnel_thread.start()"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "# Write server.py to the Colab environment\n",
